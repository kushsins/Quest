# ---------------------------------------------------------------------------
# Root Docker Compose environment (full-stack: docker-compose.yml)
#
# Copy to `.env` at the repository root and adjust as needed:
#   cp .env.docker.example .env
#
# Backend secrets (JWT_*, token lifetimes, etc.) are NOT set here; they are
# read from server/.env via `env_file`. Copy server/.env.example first:
#   cp server/.env.example server/.env
# ---------------------------------------------------------------------------

# PostgreSQL credentials (used by the postgres service and DATABASE_URL).
POSTGRES_USER=quest
POSTGRES_PASSWORD=quest
POSTGRES_DB=quest

# Host port mappings.
POSTGRES_PORT=5432
SERVER_PORT=3000
CLIENT_PORT=8080

# Allowed browser origin for the API (must match the frontend host URL).
CORS_ORIGIN=http://localhost:8080

# API base URL baked into the frontend bundle at build time.
# The browser (not the container) calls this, so it uses the host-mapped port.
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Set to "true" to run `prisma db seed` on backend startup (roles, users, tickets).
SEED_ON_START=false
